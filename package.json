{
  "name": "processing-ts",
  "version": "0.0.1",
  "description": "A Processing.js TypeScript port",
  "homepage": "https://github.com/joknoll/processing-ts#readme",
  "bugs": {
    "url": "https://github.com/joknoll/processing-ts/issues"
  },
  "license": "MIT",
  "author": "Johannes Knoll <git@joknoll.de>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joknoll/processing-ts.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./browser": "./dist/browser-esm.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "prepare": "vp config",
    "test": "vp test run --project unit",
    "test:browser": "vp test run --project browser",
    "test:browser:update": "vp test run --project browser -u",
    "test:bench": "vp test bench --project bench",
    "test:watch": "vp test watch --project unit"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "bumpp": "^11.0.1",
    "happy-dom": "^20.8.8",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite-plus": "^0.1.14"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
